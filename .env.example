DEBUG=False
SECRET_KEY=${{RAILWAY_PROJECT_ID}}-${{RAILWAY_SERVICE_ID}}-${{RAILWAY_ENVIRONMENT_ID}}

ALLOWED_HOSTS=${{RAILWAY_PUBLIC_DOMAIN}},localhost,127.0.0.1
WEBSITE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}

# If Postgres service name is "Postgres", use:
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# If not set, app auto-allows CORS on Railway.
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
CORS_ALLOW_ALL_ORIGINS=True

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=app-password
DEFAULT_FROM_EMAIL=your-email@example.com
